{
	"name": "mock-torznab",
	"version": "1.0.0",
	"description": "A mock Torznab server.",
	"type": "module",
	"main": "./dist/server.js",
	"types": "./dist/server.d.ts",
	"files": [
		"dist/"
	],
	"exports": {
		".": {
			"types": "./dist/server.d.ts",
			"default": "./dist/server.js"
		},
		"./server.js": {
			"types": "./dist/server.d.ts",
			"default": "./dist/server.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"prestart": "npm run build",
		"start": "node dist/server.js",
		"lint": "biome lint .",
		"lint:fix": "biome lint --apply .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"bencode": "^2.0.1",
		"fast-xml-parser": "^4.0.0",
		"fastify": "^5.7.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.2",
		"@types/node": "^24.3.0",
		"typescript": "^5.9.2"
	}
}
